{
  "name": "carecompanion-monorepo",
  "private": true,
  "packageManager": "bun@1.3.11",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "typecheck": "turbo run typecheck",
    "lint": "turbo run lint",
    "test:run": "turbo run test:run",
    "prepare": "husky",
    "seed:test-users": "cd apps/web && bun scripts/seed-test-users.ts",
    "deadcode": "knip"
  },
  "devDependencies": {
    "husky": "^9.1.7",
    "knip": "^6.11.0",
    "lint-staged": "^16.4.0",
    "turbo": "^2.0.0",
    "typescript": "^5"
  },
  "lint-staged": {
    "apps/web/**/*.{ts,tsx}": [
      "bash -c 'cd apps/web && ./node_modules/.bin/next lint --fix --file \"$@\"' --"
    ]
  },
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "expo-image-picker": "16.0.6"
  },
  "version": "0.3.1.0"
}
