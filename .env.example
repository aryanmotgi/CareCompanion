# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Anthropic (AI chat, summaries, extraction)
ANTHROPIC_API_KEY=

# Resend (welcome emails, notifications)
# Get your key at https://resend.com/api-keys
RESEND_API_KEY=

# Cron auth (for scheduled jobs)
CRON_SECRET=

# Site URL (used in email links)
NEXT_PUBLIC_SITE_URL=https://carecompanionai.org

# Optional: Logging level (debug|info|warn|error)
LOG_LEVEL=info

# OAuth integrations (optional)
GOOGLE_CALENDAR_CLIENT_ID=
GOOGLE_CALENDAR_CLIENT_SECRET=
ONEUP_CLIENT_ID=
ONEUP_CLIENT_SECRET=

# Slow Network Simulator (development/staging only)
NEXT_PUBLIC_NETWORK_DELAY_MS=0

# NextAuth / Auth.js
AUTH_SECRET=  # openssl rand -base64 32

# Database (Supabase Postgres connection string)
DATABASE_URL=

# Cognito (user authentication)
COGNITO_USER_POOL_ID=
COGNITO_CLIENT_ID=
COGNITO_REGION=us-east-1

# Web Push Notifications (VAPID)
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=

# Upstash Redis (distributed rate limiting)
KV_REST_API_URL=
KV_REST_API_TOKEN=

# === Testing Infrastructure ===

# E2E test endpoint protection (required for /api/e2e/signin)
E2E_AUTH_SECRET=  # openssl rand -base64 32

# Test Mode (staging/preview only)
NEXT_PUBLIC_TEST_MODE=false

# GitHub bug report integration
GITHUB_FEEDBACK_TOKEN=
GITHUB_FEEDBACK_REPO=owner/repo

# PostHog Analytics
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# Sentry error monitoring
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_DSN=
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=
